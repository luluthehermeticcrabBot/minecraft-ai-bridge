# --- LLM Provider: pick ONE ---

# OpenAI
# LLM_OPENAI_API_KEY=sk-your-openai-api-key
# LLM_MODEL=gpt-4o

# Anthropic
# LLM_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# LLM_MODEL=claude-sonnet-4-20250514
# pip install minecraft-ai-bridge[anthropic]

# Ollama (local)
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3

# OpenRouter (OpenAI-compatible proxy — 200+ models)
# OPENROUTER_API_KEY=sk-or-your-openrouter-key

# OpenCode Server (attachable inference server)
# LLM_OPencode_SERVER_URL=http://localhost:4096
# LLM_OPencode_SERVER_API_KEY=
# LLM_OPencode_SERVER_MODEL=big-pickle

